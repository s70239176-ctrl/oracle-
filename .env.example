# ─────────────────────────────────────────
# QuantChain Oracle — Environment Variables
# ─────────────────────────────────────────
# Copy this file to .env and fill in your values

# Required: OpenGradient wallet private key
# Get free test tokens at https://faucet.opengradient.ai
OG_PRIVATE_KEY=your_ethereum_private_key_here

# Optional: Use real web/news APIs instead of mock data
USE_REAL_SOURCES=false

# Optional: Brave Search API for real web search
# Get key at https://api.search.brave.com
BRAVE_API_KEY=

# Optional: NewsAPI for real news oracle
# Get key at https://newsapi.org
NEWS_API_KEY=

# Optional: Webhook server API key (for auth)
ORACLE_API_KEY=

# Optional: Webhook signature secret (for HMAC verification)
WEBHOOK_SECRET=

# Optional: OpenGradient network (testnet or alpha)
OG_RPC_URL=https://rpc.opengradient.ai
